{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "backend": {
      "build": {
        "builder": "dockerfile",
        "dockerfile": "backend/Dockerfile"
      },
      "port": 3000,
      "env": {
        "NODE_ENV": "production",
        "PORT": "3000"
      }
    },
    "frontend": {
      "build": {
        "builder": "dockerfile",
        "dockerfile": "frontend/Dockerfile"
      },
      "port": 3000,
      "env": {
        "VITE_API_URL": "${{ services.backend.variables.RAILWAY_PUBLIC_DOMAIN }}/api"
      },
      "depends_on": ["backend"]
    }
  }
}
